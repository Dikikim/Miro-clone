# Supabase — frontend (safe to expose; protected by Row Level Security)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# NOTE: the sb_secret_... key is server-only. NEVER put it here or in any
# VITE_-prefixed var (those get bundled into the browser). It bypasses RLS.
